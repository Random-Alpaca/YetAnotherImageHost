# Copy to .env and fill in. Never commit the real .env.

# Where the Express app listens. Keep it on loopback — Nginx is the only thing
# that should reach it.
HOST=127.0.0.1
PORT=3000

# Storage roots. These must match the paths in deploy/nginx.conf.
#   PUBLIC  is mapped to a public Nginx location and served directly.
#   PRIVATE is served ONLY via X-Accel-Redirect through the internal location.
STORAGE_PUBLIC=/srv/images/public
STORAGE_PRIVATE=/srv/images/private

# SQLite database file.
DB_PATH=/srv/app/data.db

# Secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=replace-me-with-a-long-random-string

# Set true in production (cookies only sent over HTTPS).
COOKIE_SECURE=true

# Max upload size in bytes (must be <= nginx client_max_body_size). 25 MB.
MAX_UPLOAD_BYTES=26214400

# Max number of files accepted in a single bulk upload request.
MAX_UPLOAD_FILES=50

# Session lifetime in days.
SESSION_TTL_DAYS=30

# The internal Nginx location prefix used for X-Accel-Redirect. Must match the
# `location /internal/` block in nginx.conf.
INTERNAL_PREFIX=/internal

# DEV ONLY. When true, the app serves image bytes itself so you can run the
# whole stack locally without Nginx. MUST be false (or unset) in production —
# in prod Nginx serves public images and honors X-Accel-Redirect for private.
DEV_DIRECT_SERVE=false
